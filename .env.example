# Site24x7 AI Directory Environment Configuration
# Copy this file to .env and configure for your deployment

# The port where the proxy server will run
PROXY_PORT=3334

# The URL where the frontend is hosted. The proxy will only accept requests from this origin.
# For local dev: http://localhost:3333
ALLOWED_ORIGIN=http://localhost:3333

# Synthetic Dataset Generation Config
# Provider can be 'openai'
LLM_PROVIDER=openai
OPENAI_BASE_URL=http://your-proxy.example.com/openai
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=azure:primary/gpt-4.1
